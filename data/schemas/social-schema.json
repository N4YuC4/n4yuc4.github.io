{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Social Links Schema",
  "description": "Schema for validating and editing contact and social media profiles",
  "type": "object",
  "properties": {
    "email": { "type": "string", "format": "email", "description": "Primary email address" },
    "website": {
      "type": "object",
      "properties": {
        "url": { "type": "string", "description": "Personal website URL" },
        "display": { "type": "string", "description": "Display name of personal website" }
      },
      "required": ["url", "display"]
    },
    "links": {
      "type": "array",
      "description": "List of social profiles (LinkedIn, GitHub, Kaggle, ORCID, etc.)",
      "items": {
        "type": "object",
        "properties": {
          "platform": { "type": "string", "description": "Social platform name" },
          "url": { "type": "string", "description": "Profile URL" },
          "display": { "type": "string", "description": "Display text for the link" },
          "svgPath": { "type": "string", "description": "Optional inline SVG path definition" },
          "svgCircle": { "type": "boolean", "description": "Whether to draw a background circle in the SVG macro" },
          "imgUrl": { "type": "string", "description": "Alternative image URL if not using inline SVG" },
          "isImg": { "type": "boolean", "description": "Must be set to true if imgUrl is provided instead of svgPath" }
        },
        "required": ["platform", "url", "display"]
      }
    }
  },
  "required": ["email", "website", "links"]
}
