{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CV Data Schema",
  "description": "Schema for validating and editing Nazmi Yucel Can CV data",
  "type": "object",
  "properties": {
    "personalInfo": {
      "type": "object",
      "properties": {
        "firstName": { "type": "string", "description": "First name of the person" },
        "lastName": { "type": "string", "description": "Last name of the person" },
        "title": { "type": "string", "description": "Professional title (e.g. Machine Learning Scientist)" },
        "profileImage": { "type": "string", "description": "Path to the profile photo in static directory (e.g., images/profile.png)" }
      },
      "required": ["firstName", "lastName", "title"]
    },
    "professionalSummary": {
      "type": "string",
      "description": "A brief overview of professional background and key strengths"
    },
    "skills": {
      "type": "array",
      "description": "Categorized list of technical skills",
      "items": {
        "type": "object",
        "properties": {
          "category": { "type": "string", "description": "Category name (e.g., Programming Languages)" },
          "skill_list": {
            "type": "array",
            "items": { "type": "string" },
            "description": "List of skills in this category"
          }
        },
        "required": ["category", "skill_list"]
      }
    },
    "education": {
      "type": "array",
      "description": "Educational background history",
      "items": {
        "type": "object",
        "properties": {
          "degree": { "type": "string", "description": "Degree type (e.g. Bachelor of Science, Lisans)" },
          "field": { "type": "string", "description": "Field of study (e.g. Computer Science)" },
          "institution": { "type": "string", "description": "Name of the university/school" },
          "startYear": { "type": "string", "description": "Start date (MM/YYYY)" },
          "endYear": { "type": "string", "description": "Graduation or expected end date (MM/YYYY or Present)" },
          "gpa": { "type": "string", "description": "GPA score (e.g., 3.17/4.00)" }
        },
        "required": ["degree", "institution", "startYear", "endYear"]
      }
    },
    "experiences": {
      "type": "array",
      "description": "Professional work history",
      "items": {
        "type": "object",
        "properties": {
          "title": { "type": "string", "description": "Job title (e.g., Machine Learning Intern)" },
          "company": { "type": "string", "description": "Company or organization name" },
          "startDate": { "type": "string", "description": "Start date (MM/YYYY)" },
          "endDate": { "type": "string", "description": "End date (MM/YYYY or Present)" },
          "description": {
            "anyOf": [
              {
                "type": "array",
                "items": { "type": "string" },
                "description": "List of bullet points describing responsibilities and achievements"
              },
              {
                "type": "string",
                "description": "Text description of responsibilities and achievements"
              }
            ]
          }
        },
        "required": ["title", "company", "startDate", "endDate"]
      }
    },
    "languages": {
      "type": "array",
      "description": "Spoken languages and proficiency levels",
      "items": {
        "type": "object",
        "properties": {
          "language": { "type": "string", "description": "Language name (e.g. English, Türkçe)" },
          "level": { "type": "string", "description": "Proficiency level (e.g. Native, Intermediate)" }
        },
        "required": ["language", "level"]
      }
    },
    "publications": {
      "type": "array",
      "description": "Academic publications (usually populated programmatically by the build system)",
      "items": {
        "type": "object"
      }
    },
    "references": {
      "type": "array",
      "description": "Professional or academic references",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "description": "Reference person's name" },
          "title": { "type": "string", "description": "Reference person's title" },
          "company": { "type": "string", "description": "Reference person's company or institution" },
          "email": { "type": "string", "description": "Email address" },
          "phone": { "type": "string", "description": "Phone number" }
        },
        "required": ["name"]
      }
    }
  },
  "required": ["personalInfo"]
}
